<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFrameworks>net48;net10.0-windows</TargetFrameworks>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Platforms>AnyCPU;x64;ARM64</Platforms>
    <RuntimeIdentifiers>win-x64;win-arm64</RuntimeIdentifiers>
    <LangVersion>latest</LangVersion>
    <ForceDesignerDpiUnaware>true</ForceDesignerDpiUnaware>
    <GeneratePathProperty>true</GeneratePathProperty>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <PropertyGroup Condition="'$(TargetFramework)' == 'net48'">
    <GenerateResourceWarnOnBinaryFormatterUse>false</GenerateResourceWarnOnBinaryFormatterUse>
    <GenerateResourceUsePreserializedResources>true</GenerateResourceUsePreserializedResources>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="TestSupport\**" />
    <EmbeddedResource Remove="TestSupport\**" />
    <None Remove="TestSupport\**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CDS.WinFormsMenus" Version="1.1.3" />
    <PackageReference Include="Humanizer.Core" Version="3.0.10" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="OpenCvSharp4.Extensions" Version="4.13.0.20260602" />
    <PackageReference Include="OpenCvSharp4.Windows" Version="4.13.0.20260602" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net48'">
    <PackageReference Include="System.Resources.Extensions" Version="10.0.8" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\CDS.CSharpScript2.RTFEditor\CDS.CSharpScript2.RTFEditor.csproj" />
    <ProjectReference Include="..\CDS.CSharpScript2.ScintillaEditor\CDS.CSharpScript2.ScintillaEditor.csproj" />
    <ProjectReference Include="..\TestUtils\TestUtils.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="Demos\FormRTFDemo.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="Demos\BasicDemo\FormBasicDemo.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="Demos\OpenCvSharpStaticDemo\FormOpenCvSharpDemo.cs">
      <SubType>Form</SubType>
    </Compile>
    <Compile Update="Demos\ClassifiedSpansDemo\FormDemo.cs">
      <SubType>Form</SubType>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <None Update="Demos\OpenCvSharpStaticDemo\IMG_1412.jpeg">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Update="MinVer" Version="7.0.0" />
  </ItemGroup>

  <!--This copies all the XML documentation files to the output folder! -->
  <PropertyGroup>
    <CopyDocumentationFilesFromPackages>true</CopyDocumentationFilesFromPackages>
  </PropertyGroup>
  
</Project>
